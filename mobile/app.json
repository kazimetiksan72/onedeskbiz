{
  "expo": {
    "name": "SmallBiz Mobile",
    "slug": "smallbiz-mobile",
    "scheme": "smallbizmobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pikselmutfak.onedesk",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Profil ve masraf belgesi fotoğrafı çekmek için kamera erişimi gerekiyor.",
        "NSPhotoLibraryUsageDescription": "Masraf belgesi fotoğraflarını seçmek için fotoğraf arşivi erişimi gerekiyor.",
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "NSLocationWhenInUseUsageDescription": "Konum bilgisi, yalnızca bildirim ve uygulama özellikleri için gerekli olduğunda kullanılır."
      },
      "icon": "./assets/icon.png"
    },
    "android": {},
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "b1e63e76-a381-46cc-8a77-da312b788ae9"
      },
      "oneSignalAppId": ""
    },
    "plugins": [
      [
        "onesignal-expo-plugin",
        {
          "mode": "production"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "icon": "./assets/icon.png"
  }
}
